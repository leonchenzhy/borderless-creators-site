---
import BaseLayout from '../layouts/BaseLayout.astro';
// HeroSignalField kept as component file for future use — not rendered while hero-banner.png is active

const projects = [
  {
    id: 'neural-field',
    name: 'Neural Field',
    statusLabel: 'LIVE',
    pillClass: 'bc-pill-live',
    showDot: true,
    category: 'INTELLIGENCE',
    accentColor: '#22D3EE',
    description: 'AI-powered news intelligence for tracking the frontier of AI, sports, gaming, platforms, and creative technology.',
    url: 'https://ainews.borderlesscreators.com/',
    ctaLabel: 'VIEW PROJECT →',
  },
  {
    id: 'digital-leon',
    name: 'Digital Leon',
    statusLabel: 'IN LAB',
    pillClass: 'bc-pill-upcoming',
    showDot: false,
    category: 'IDENTITY',
    accentColor: '#2DD4BF',
    description: 'A digital identity experiment exploring AI agents, synthetic media, and more human ways to introduce ideas.',
    url: null,
    ctaLabel: null,
  },
  {
    id: 'world-model-studio',
    name: 'World Model Studio',
    statusLabel: 'IN LAB',
    pillClass: 'bc-pill-lab',
    showDot: false,
    category: 'WORLDS',
    accentColor: '#3B82F6',
    description: 'Experiments in AI-assisted scene creation, spatial storytelling, and worldbuilding workflows for games and interactive media.',
    url: null,
    ctaLabel: null,
  },
  {
    id: 'manga-lab',
    name: 'Manga Lab',
    statusLabel: 'UPCOMING',
    pillClass: 'bc-pill-lab',
    showDot: false,
    category: 'STORIES',
    accentColor: '#A78BFA',
    description: 'AI-assisted manga experiments blending character design, visual narrative, humor, mythology, and cross-cultural storytelling.',
    url: null,
    ctaLabel: null,
  },
];

---

<BaseLayout>
  <!-- ────────────────────────────────────────────────────────────────────── -->
  <!-- NAV                                                                   -->
  <!-- ────────────────────────────────────────────────────────────────────── -->
  <header class="bc-header" id="site-header">
    <nav
      class="mx-auto flex max-w-6xl items-center justify-between px-8 py-7"
      aria-label="Main navigation"
    >
      <!-- Wordmark -->
      <a href="/" class="flex items-center no-underline" aria-label="Borderless Creators — home">
        <img
          src="/logo-nav.png"
          alt="Borderless Creators"
          height="38"
          style="height:38px; width:auto; display:block;"
        />
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-6">
        <a href="https://leonchen.ai" target="_blank" rel="noopener noreferrer" class="nav-link">leonchen.ai ↗</a>
        <a href="mailto:contact@borderlesscreators.com" class="nav-link">Contact</a>
        <a
          href="https://ainews.borderlesscreators.com/"
          target="_blank"
          rel="noopener"
          class="bc-btn-primary"
          style="padding: 9px 18px;"
        >Enter Neural Field</a>
      </div>

      <!-- Mobile toggle -->
      <label class="cursor-pointer md:hidden" for="mob-toggle" aria-label="Open navigation">
        <svg width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
          <line x1="0" y1="1"  x2="22" y2="1"  stroke="#64748B" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="0" y1="8"  x2="22" y2="8"  stroke="#64748B" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="0" y1="15" x2="14" y2="15" stroke="#64748B" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </label>
    </nav>

    <!-- Mobile menu -->
    <input type="checkbox" id="mob-toggle" class="sr-only peer" />
    <div class="mob-menu hidden peer-checked:flex flex-col md:hidden px-8 py-4 gap-3 border-t bc-divider">
      <a href="https://leonchen.ai" target="_blank" rel="noopener noreferrer" class="nav-link-mob">leonchen.ai ↗</a>
      <a href="mailto:contact@borderlesscreators.com" class="nav-link-mob">Contact</a>
      <a href="https://ainews.borderlesscreators.com/" target="_blank" rel="noopener noreferrer" class="bc-btn-primary mt-1 self-start">Enter Neural Field</a>
    </div>
  </header>

  <main id="main-content">
    <!-- ──────────────────────────────────────────────────────────────────── -->
    <!-- HERO                                                                -->
    <!-- ──────────────────────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden" style="min-height: 100vh; min-height: 100svh; display:flex; align-items:center;" aria-label="Hero">
      <!-- Hero banner image — primary background -->
      <img
        src="/hero-banner.webp"
        alt=""
        aria-hidden="true"
        width="1586"
        height="992"
        decoding="async"
        fetchpriority="high"
        class="pointer-events-none absolute inset-0 w-full h-full"
        style="object-fit:cover; object-position:center center; z-index:1;"
      />

      <!-- Top fade — keeps nav readable over the banner image -->
      <div
        class="pointer-events-none absolute top-0 left-0 right-0 z-10"
        style="height:200px; background:linear-gradient(to bottom, rgba(2,6,23,0.82) 0%, rgba(2,6,23,0.35) 65%, transparent 100%);"
        aria-hidden="true"
      ></div>

      <!-- Bottom fade into base -->
      <div
        class="pointer-events-none absolute bottom-0 left-0 right-0 z-10"
        style="height:160px; background:linear-gradient(to bottom, transparent, #020617);"
        aria-hidden="true"
      ></div>

      <div class="relative z-20 mx-auto w-full max-w-6xl px-8" style="padding-top: clamp(90px, 12vh, 180px); padding-bottom: clamp(60px, 8vh, 120px);">
        <!-- Eyebrow -->
        <div class="flex items-center gap-2.5 mb-7 anim-fade-up">
          <span class="signal-dot"></span>
          <span class="bc-eyebrow" style="color:#2DD4BF;">An AI-native lab by Leon Chen</span>
        </div>

        <!-- H1 -->
        <h1
          class="font-display font-semibold mb-6 anim-fade-up anim-d1"
          style="font-size: clamp(44px, 6vw, 72px); line-height:1.04; letter-spacing:-0.02em; max-width:700px;"
        >
          Creative systems<br/>
          <span class="text-gradient">for the intelligence era.</span>
        </h1>

        <!-- Body -->
        <p
          class="mb-10 anim-fade-up anim-d2"
          style="font-weight:300; font-size:clamp(15px,1.4vw,18px); line-height:1.65; color:rgba(148,163,184,0.85); max-width:460px;"
        >
          Experiments across news intelligence, digital identity, worldbuilding, and AI-assisted storytelling.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 anim-fade-up anim-d3">
          <a
            href="#projects"
            class="bc-btn-primary"
          >Enter the Lab</a>
        </div>
      </div>
    </section>

    <!-- ──────────────────────────────────────────────────────────────────── -->
    <!-- PROJECT UNIVERSE                                                    -->
    <!-- ──────────────────────────────────────────────────────────────────── -->
    <section id="projects" class="flex items-center" style="min-height:100vh; min-height:100svh; padding: 80px 0; scroll-margin-top: 80px;" aria-labelledby="projects-heading">
      <div class="mx-auto w-full max-w-6xl px-8">
        <!-- Section header -->
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="bc-eyebrow mb-2">The Lab</p>
            <h2 id="projects-heading" class="font-display font-semibold text-[#F1F5F9]"
              style="font-size:clamp(24px,3vw,34px); letter-spacing:-0.02em;">Current Experiments</h2>
          </div>
        </div>

        <!-- 2-col project grid -->
        <div class="grid gap-4 sm:grid-cols-2">
          {projects.map((p) => (
            p.id === 'neural-field' ? (
              <!-- Neural Field — LIVE card -->
              <article
                class="bc-card-live group relative overflow-hidden"
                style={`--card-accent: ${p.accentColor};`}
              >
                <!-- Animated top accent line -->
                <div class="absolute top-0 left-0 right-0 h-px live-accent-line" aria-hidden="true"></div>

                <!-- Top row: category + status -->
                <div class="flex items-center justify-between mb-5">
                  <span
                    class="font-mono-bc text-[9px] tracking-[0.2em] uppercase"
                    style={`color:${p.accentColor}; opacity:0.85;`}
                  >{p.category}</span>
                  <span class="bc-pill bc-pill-live" style="gap:5px;">
                    <span class="signal-dot" style="width:5px;height:5px;"></span>
                    {p.statusLabel}
                  </span>
                </div>

                <!-- Name -->
                <h3 class="font-display font-semibold text-[#F1F5F9] mb-2.5"
                  style="font-size:clamp(18px,2vw,22px); letter-spacing:-0.01em; line-height:1.2;">
                  {p.name}
                </h3>

                <!-- Description -->
                <p class="text-[13px] leading-relaxed mb-7"
                  style="color:rgba(148,163,184,0.78); font-weight:300;">
                  {p.description}
                </p>

                <!-- CTA — always visible for live card -->
                <a
                  href={p.url!}
                  target="_blank"
                  rel="noopener"
                  class="bc-btn-primary inline-block"
                  style="font-size:11px; padding:8px 16px;"
                  aria-label={`${p.name} — opens in new tab`}
                >
                  {p.ctaLabel}
                </a>
              </article>
            ) : (
              <!-- Standard card -->
              <article
                class="bc-card group"
                style={`--card-accent: ${p.accentColor};`}
              >
                <!-- Top row: category + status -->
                <div class="flex items-center justify-between mb-5">
                  <span
                    class="font-mono-bc text-[9px] tracking-[0.2em] uppercase"
                    style={`color:${p.accentColor}; opacity:0.85;`}
                  >{p.category}</span>
                  <span class={`bc-pill ${p.pillClass}`}>
                    {p.showDot && <span class="signal-dot" style="width:4px;height:4px;"></span>}
                    {p.statusLabel}
                  </span>
                </div>

                <!-- Name -->
                <h3 class="font-display font-semibold text-[#F1F5F9] mb-2.5"
                  style="font-size:clamp(18px,2vw,22px); letter-spacing:-0.01em; line-height:1.2;">
                  {p.name}
                </h3>

                <!-- Description -->
                <p class="text-[13px] leading-relaxed mb-7"
                  style="color:rgba(148,163,184,0.78); font-weight:300;">
                  {p.description}
                </p>

                <!-- CTA -->
                {p.url && p.ctaLabel && (
                  <a
                    href={p.url}
                    target="_blank"
                    rel="noopener"
                    class="font-mono-bc text-[10px] tracking-[0.14em] uppercase transition-opacity duration-200 opacity-0 group-hover:opacity-100"
                    style={`color:${p.accentColor}; text-decoration:none;`}
                    aria-label={`${p.name} — opens in new tab`}
                  >
                    {p.ctaLabel}
                  </a>
                )}
              </article>
            )
          ))}
        </div>
      </div>
    </section>

    <!-- ──────────────────────────────────────────────────────────────────── -->
    <!-- PHILOSOPHY / ABOUT                                                  -->
    <!-- ──────────────────────────────────────────────────────────────────── -->
    <section class="bc-philosophy" aria-labelledby="philosophy-heading">
      <div class="mx-auto w-full max-w-6xl px-8">
        <div class="philosophy-grid">

          <!-- Text block -->
          <div class="philosophy-text">
            <p class="bc-eyebrow mb-5" style="color:#2DD4BF;">About Borderless Creators</p>
            <h2
              id="philosophy-heading"
              class="font-display font-semibold text-[#F1F5F9] mb-8"
              style="font-size:clamp(28px,3.5vw,44px); letter-spacing:-0.02em; line-height:1.1;"
            >
              Create beyond borders,<br/>
              <span class="text-gradient">build with intelligence.</span>
            </h2>
            <div class="philosophy-copy">
              <p>The next era of creation will not be defined by borders. Human and machine. Strategy and art. Technology and culture. Imagination and reality. These boundaries are dissolving and becoming creative material.</p>
              <p>Ideas accelerate into experiences. Experiences become stories. Stories awaken intelligence. Intelligence expands imagination. With AI and beyond.</p>
              <p class="philosophy-invitation">Borderless Creators is our invitation into that loop: to build, explore, and imagine what comes next.</p>
            </div>
          </div>

          <!-- Visual block -->
          <div class="philosophy-visual" aria-hidden="true">
            <div class="philosophy-glow"></div>
            <img src="/brand-mark.webp" alt="" class="philosophy-mark" width="340" height="340" loading="lazy" decoding="async" />
          </div>

        </div>
      </div>
    </section>

  </main>

  <!-- ──────────────────────────────────────────────────────────────────────── -->
  <!-- FOOTER                                                                 -->
  <!-- ──────────────────────────────────────────────────────────────────────── -->
  <footer class="py-6">
    <div class="mx-auto max-w-6xl px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Logo -->
      <a href="/" aria-label="Borderless Creators — home">
        <img
          src="/logo-nav.png"
          alt="Borderless Creators"
          height="24"
          style="height:24px; width:auto; display:block; opacity:0.5;"
        />
      </a>
      <!-- Copyright -->
      <p class="font-mono-bc text-[10px] tracking-[0.06em]" style="color:rgba(100,116,139,0.45);">
        &copy; {new Date().getFullYear()} Borderless Creators. Built with
        <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" class="hover:text-[#2DD4BF] transition-colors" style="color:rgba(100,116,139,0.6);">Astro</a>
        &amp;
        <a href="https://pages.cloudflare.com/" target="_blank" rel="noopener noreferrer" class="hover:text-[#2DD4BF] transition-colors" style="color:rgba(100,116,139,0.6);">Cloudflare Pages</a>.
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Philosophy / About section */
  .bc-philosophy {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 140px 0 80px; /* extra top padding nudges content below visual centre */
    background: linear-gradient(180deg, #020617 0%, #040d1a 50%, #020617 100%);
  }
  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .philosophy-copy p {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(148,163,184,0.82);
    font-weight: 300;
    margin-bottom: 18px;
  }
  .philosophy-copy p:last-child { margin-bottom: 0; }
  .philosophy-invitation {
    color: rgba(241,245,249,0.88) !important;
    border-left: 2px solid #2DD4BF;
    padding-left: 18px;
    margin-top: 32px !important;
    font-style: italic;
  }
  .philosophy-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .philosophy-glow {
    position: absolute;
    inset: -60px;
    background: radial-gradient(ellipse 75% 75% at 50% 50%,
      rgba(34,211,238,0.09) 0%,
      rgba(59,130,246,0.06) 45%,
      transparent 70%);
    pointer-events: none;
  }
  .philosophy-mark {
    width: 100%;
    max-width: 340px;
    height: auto;
    display: block;
    filter:
      drop-shadow(0 0 28px rgba(34,211,238,0.28))
      drop-shadow(0 0 64px rgba(34,211,238,0.12));
    opacity: 0.88;
  }
  @media (max-width: 768px) {
    .philosophy-grid {
      grid-template-columns: 1fr;
      gap: 52px;
    }
    .philosophy-visual { order: -1; }
    .philosophy-mark { max-width: 180px; margin: 0 auto; }
  }

  /* Live card */
  .bc-card-live {
    background: linear-gradient(135deg, #07111F 0%, rgba(11,23,38,0.7) 100%);
    border: 1px solid rgba(34,211,238,0.25);
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 0 32px rgba(34,211,238,0.06), inset 0 0 40px rgba(34,211,238,0.03);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .bc-card-live:hover {
    border-color: rgba(34,211,238,0.45);
    box-shadow: 0 0 48px rgba(34,211,238,0.1), inset 0 0 40px rgba(34,211,238,0.04);
  }
  .live-accent-line {
    background: linear-gradient(90deg, transparent, rgba(34,211,238,0.55), rgba(45,212,191,0.4), transparent);
    animation: live-pulse 3s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1; }
  }

  /* Nav links */
  .nav-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #64748B;
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .nav-link:hover { color: #2DD4BF; }

  .nav-link-mob {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #64748B;
    text-decoration: none;
    padding: 8px 0;
    display: block;
    transition: color 0.18s ease;
  }
  .nav-link-mob:hover { color: #2DD4BF; }

  /* ── Sticky header ── */
  .bc-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.35s ease,
      border-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }
  .bc-header.scrolled {
    background-color: rgba(2, 6, 23, 0.84);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }
  /* Mobile menu needs its own opaque background regardless of scroll state */
  .bc-header .mob-menu {
    background: #07111F;
  }
</style>

<script>
  (function () {
    const header = document.getElementById('site-header');
    if (!header) return;
    const THRESHOLD = 40;

    function update() {
      header.classList.toggle('scrolled', window.scrollY > THRESHOLD);
    }

    update(); // run once on load in case page is already scrolled
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>
