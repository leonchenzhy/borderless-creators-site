---
/**
 * HeroSignalField.astro
 * Topographic contour field — animated canvas background for the hero.
 * Pure client-side canvas animation (no deps).
 * Gracefully degrades: canvas replaced by CSS gradient if JS is unavailable.
 * Respects prefers-reduced-motion.
 */
---

<div class="topo-field" aria-hidden="true">
  <!-- Fallback for no-JS / reduced-motion -->
  <div class="topo-fallback"></div>
  <!-- Canvas fills container via JS -->
  <canvas id="topo-canvas" class="topo-canvas"></canvas>
</div>

<script>
  (function () {
    const canvas = document.getElementById('topo-canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return; // Leave the CSS fallback visible

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let raf;
    let t = 0;

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width  = rect.width  * window.devicePixelRatio;
      canvas.height = rect.height * window.devicePixelRatio;
      canvas.style.width  = rect.width  + 'px';
      canvas.style.height = rect.height + 'px';
    }

    function draw() {
      const W = canvas.width;
      const H = canvas.height;

      ctx.clearRect(0, 0, W, H);

      // ── Background ──────────────────────────────────────────────
      const bg = ctx.createRadialGradient(W * 0.5, H * 0.35, 0, W * 0.5, H * 0.35, W * 0.72);
      bg.addColorStop(0,   'rgba(11,23,38,0.98)');
      bg.addColorStop(0.5, 'rgba(7,17,31,0.99)');
      bg.addColorStop(1,   'rgba(2,6,23,1)');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, W, H);

      // ── Topographic contour lines ────────────────────────────────
      const lines = 16;
      for (let i = 0; i < lines; i++) {
        const phase    = (i / lines) * Math.PI * 2;
        const amp      = (22 + i * 9) * (H / 600);
        const freq     = 0.0035 + i * 0.00025;
        const yBase    = H * 0.1 + (H * 0.82 * i / lines);
        const alpha    = 0.035 + (i < 6 ? 0.025 : 0) + Math.sin(t * 0.35 + phase) * 0.012;

        ctx.beginPath();
        for (let x = 0; x <= W; x += 2) {
          const xN = x / W;
          const y  = yBase
            + Math.sin(xN * freq * W + t * 0.28 + phase) * amp
            + Math.sin(xN * freq * W * 2.1 - t * 0.16 + phase * 1.5) * amp * 0.38
            + Math.sin(xN * freq * W * 0.6 + t * 0.11) * amp * 0.28;
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }

        // Teal → blue color shift across contours
        const ratio = i / lines;
        const r     = Math.round(34  + (59  - 34)  * ratio);
        const g     = Math.round(211 + (130 - 211) * ratio);
        const b     = Math.round(238 + (246 - 238) * ratio);
        ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
        ctx.lineWidth   = 0.7;
        ctx.stroke();
      }

      // ── Subtle grid ──────────────────────────────────────────────
      ctx.strokeStyle = 'rgba(45,212,191,0.025)';
      ctx.lineWidth   = 0.5;
      const gx = 80 * (W / 1440), gy = 80 * (H / 600);
      for (let x = 0; x <= W; x += gx) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
      }
      for (let y = 0; y <= H; y += gy) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
      }

      // ── Central radial glow ──────────────────────────────────────
      const glowAlpha = 0.10 + Math.sin(t * 0.45) * 0.03;
      const glow = ctx.createRadialGradient(W * 0.5, H * 0.38, 0, W * 0.5, H * 0.38, W * 0.42);
      glow.addColorStop(0,   `rgba(34,211,238,${glowAlpha})`);
      glow.addColorStop(0.5, `rgba(59,130,246,${glowAlpha * 0.35})`);
      glow.addColorStop(1,   'transparent');
      ctx.fillStyle = glow;
      ctx.fillRect(0, 0, W, H);

      t  += 0.012;
      raf = requestAnimationFrame(draw);
    }

    resize();
    canvas.style.opacity = '1';
    draw();

    // Pause when tab is hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) { cancelAnimationFrame(raf); }
      else { t = 0; draw(); }
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => { resize(); }, 100);
    });
  })();
</script>

<style>
  .topo-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  /* CSS fallback shown when JS is off or motion is reduced */
  .topo-fallback {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 35%, rgba(11,23,38,0.98) 0%, rgba(7,17,31,0.99) 55%, rgba(2,6,23,1) 100%);
  }

  .topo-canvas {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    display: block;
  }
</style>
